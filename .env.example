# Copy this to .env and fill in values

# SearXNG instance URL (required for mcp-searxng-enhanced)
# Run your own instance or use a public one
SEARXNG_BASE_URL=http://localhost:8080

# Google Trends (optional, for google-trends-mcp)
# No API key needed - uses public Google Trends interface

# App Store Intelligence (optional, for app-insight-mcp or mcp-appstore)
# Check the specific server docs for required credentials

# Pandoc (optional, for mcp-pandoc)
# Requires pandoc installed locally: brew install pandoc
